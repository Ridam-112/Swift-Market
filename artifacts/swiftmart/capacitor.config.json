{
  "appId": "com.swiftmart.app",
  "appName": "SwiftMart",
  "webDir": "dist/public",
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "backgroundColor": "#0d0d0d",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
